<Application x:Class="BackgroundSlideShow.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
             ShutdownMode="OnExplicitShutdown">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark"/>
                <ui:ControlsDictionary/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Enum -> bool converter for RadioButtons -->
            <local:EnumToBoolConverter x:Key="EnumBoolConverter"
                xmlns:local="clr-namespace:BackgroundSlideShow"/>

            <!-- Shared Play/Resume button style for monitor cards and detail panel. -->
            <Style x:Key="PlayResumeButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Command" Value="{Binding StartCommand}"/>
                <Setter Property="Content" Value="Play"/>
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Play24" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                        <Setter Property="Command" Value="{Binding ResumeCommand}"/>
                        <Setter Property="Content" Value="Resume"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Tray icon (declared here so it lives for the application lifetime) -->
            <tb:TaskbarIcon x:Key="TrayIcon"
                            ToolTipText="Background Slideshow"
                            IconSource="pack://application:,,,/Resources/app.ico"
                            TrayMouseDoubleClick="TrayDoubleClick_Click">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open"       Click="TrayOpen_Click"/>
                        <Separator/>
                        <MenuItem Header="Start All"  Click="TrayStartAll_Click"/>
                        <MenuItem Header="Pause All"  Click="TrayPauseAll_Click"/>
                        <MenuItem Header="Resume All" Click="TrayResumeAll_Click"/>
                        <MenuItem Header="Stop All"   Click="TrayStopAll_Click"/>
                        <Separator/>
                        <MenuItem Header="Exit"       Click="TrayExit_Click"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>

        </ResourceDictionary>
    </Application.Resources>
</Application>
