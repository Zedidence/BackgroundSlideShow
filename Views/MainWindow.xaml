<Window x:Class="BackgroundSlideShow.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BackgroundSlideShow.Views"
        Title="Background Slideshow"
        Width="1000" Height="650"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Background="#1E1E1E">

        <!-- Title bar / nav -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="8,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ToggleLibraryBtn" Content="≡ Hide Library"
                            Style="{StaticResource NavButton}" Click="ToggleLibrary_Click"
                            ToolTip="Show or hide the image library sidebar"/>
                    <Button Content="Overview" Style="{StaticResource NavButton}"
                            Click="Overview_Click"
                            ToolTip="Return to the monitor overview dashboard"/>
                    <Button Content="Gallery" Style="{StaticResource NavButton}"
                            Click="Gallery_Click"
                            ToolTip="Browse all images in your library"/>
                    <Button Content="Settings" Style="{StaticResource NavButton}" Click="ShowSettings_Click"/>
                </StackPanel>
                <!-- Right-side controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="■ Stop All" Style="{StaticResource NavButton}"
                            Command="{Binding StopAllCommand}"
                            Foreground="#FF6B6B" Padding="10,6"/>
                    <Button Content="Minimize to Tray" Style="{StaticResource NavButton}"
                            Click="MinimizeToTray_Click"
                            Foreground="#AAAAAA" Padding="10,6"
                            ToolTip="Hide the window to the system tray (the app keeps running)"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main split -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LibraryColumn" Width="220" MinWidth="160" MaxWidth="320"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Library panel (folder management) -->
            <local:LibraryView x:Name="LibraryPanel" Grid.Column="0"
                               DataContext="{Binding Library.FolderList}"/>

            <GridSplitter x:Name="LibrarySplitter" Grid.Column="1" Width="4" Background="#3A3A3A"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- Right: content area -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <!-- Compact monitor bar — only visible when a monitor is selected -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Main content -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Compact monitor bar (shown only when a monitor is selected) -->
                <Border Grid.Row="0" Padding="10,8" Background="#252525">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMonitor}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="MONITORS" Foreground="#666" FontSize="10"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding Monitors}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,6,4" Padding="8,6" Background="#2D2D2D"
                                            BorderBrush="#555" BorderThickness="1"
                                            MinWidth="120" Cursor="Hand"
                                            MouseLeftButtonUp="MonitorCard_Click">
                                        <StackPanel>
                                            <!-- Name -->
                                            <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" Margin="0,0,0,3"/>
                                            <!-- Orientation badge -->
                                            <Border Padding="4,1" CornerRadius="3" Margin="0,0,0,3"
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1A4A7A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPortrait}" Value="True">
                                                                <Setter Property="Background" Value="#5A2A8A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding OrientationLabel}"
                                                           Foreground="White" FontSize="9"/>
                                            </Border>
                                            <!-- Status -->
                                            <TextBlock Text="{Binding Status}" FontSize="10" Margin="0,0,0,2">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#888"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Playing">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                <Setter Property="Foreground" Value="#FFC107"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Countdown -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="⏱ " Foreground="#666" FontSize="9"/>
                                                <TextBlock Text="{Binding NextChangeCountdown}"
                                                           Foreground="#999" FontSize="9" FontFamily="Consolas"/>
                                            </StackPanel>
                                            <!-- Pool -->
                                            <TextBlock Text="{Binding PoolDescription}"
                                                       Foreground="#666" FontSize="9"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Separator Grid.Row="1" Background="#3A3A3A">
                    <Separator.Style>
                        <Style TargetType="Separator">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMonitor}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Separator.Style>
                </Separator>

                <!-- Monitor content area: Overview + MonitorPanel (hidden when Gallery is active) -->
                <Grid x:Name="MonitorContentArea" Grid.Row="2">

                    <!-- Overview dashboard — visible by default, hidden when a monitor is selected -->
                    <local:MonitorOverviewPanel DataContext="{Binding}">
                        <local:MonitorOverviewPanel.Style>
                            <Style TargetType="local:MonitorOverviewPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMonitor}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </local:MonitorOverviewPanel.Style>
                    </local:MonitorOverviewPanel>

                    <!-- Monitor detail panel — hidden by default, visible when a monitor is selected -->
                    <ContentControl Content="{Binding SelectedMonitor}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <local:MonitorPanel DataContext="{Binding}"/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMonitor}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>

                </Grid>

                <!-- Gallery view — shown when user clicks Gallery, hidden otherwise -->
                <local:GalleryView x:Name="GalleryPanel" Grid.Row="2"
                                   DataContext="{Binding Library.Gallery}"
                                   Visibility="Collapsed"/>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
