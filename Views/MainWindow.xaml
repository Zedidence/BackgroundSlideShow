<ui:FluentWindow x:Class="BackgroundSlideShow.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:BackgroundSlideShow.Views"
        Title="Background Slideshow"
        Width="1050" Height="680"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar x:Name="TitleBar" Title="Background Slideshow" Grid.Row="0"/>

        <!-- Main body: nav pane + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left navigation pane -->
            <ui:NavigationView x:Name="RootNavigation"
                               Grid.Column="0"
                               PaneDisplayMode="Left"
                               IsBackButtonVisible="Collapsed"
                               OpenPaneLength="180"
                               IsPaneOpen="True"
                               SelectionChanged="RootNavigation_SelectionChanged">

                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Content="Overview" Tag="overview"
                                           ToolTip="Monitor overview dashboard">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Grid24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                    <ui:NavigationViewItem Content="Gallery" Tag="gallery"
                                           ToolTip="Browse all images in your library">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Image24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                    <ui:NavigationViewItem Content="GIF Mode" Tag="gif"
                                           ToolTip="Play animated GIFs as live desktop wallpaper">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Filmstrip24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                    <ui:NavigationViewItem Content="Lock Screen" Tag="lockscreen"
                                           ToolTip="Set a custom Windows lock screen image">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="LockClosed24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.MenuItems>

                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem Content="Settings" Tag="settings"
                                           ToolTip="Application settings">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Settings24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>

            <!-- Right: content area with optional library sidebar -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LibraryColumn" Width="220" MinWidth="160" MaxWidth="320"/>
                    <ColumnDefinition x:Name="SplitterColumn" Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Library panel (folder management) -->
                <local:LibraryView x:Name="LibraryPanel" Grid.Column="0"
                                   DataContext="{Binding Library.FolderList}"/>

                <GridSplitter x:Name="LibrarySplitter" Grid.Column="1" Width="4"
                              Background="Transparent"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                <!-- Main content -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header: Stop All + To Tray buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,8,12,4">
                        <Button Command="{Binding StopAllCommand}"
                                ToolTip="Stop all slideshows" Margin="0,0,8,0"
                                Background="#3A1A1A" Foreground="#FF6B6B" BorderBrush="#5C2A2A">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Stop24" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Stop All"/>
                            </StackPanel>
                        </Button>
                        <Button Click="MinimizeToTray_Click"
                                ToolTip="Hide the window to the system tray"
                                Background="Transparent" Foreground="#AAAAAA" BorderThickness="0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowMinimize24" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="To Tray"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Compact monitor bar (shown only when a monitor is selected) -->
                    <Border Grid.Row="1" Padding="12,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMonitor}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="MONITORS"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Monitors}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,8,6" Padding="10,8" CornerRadius="6"
                                                MinWidth="130" Cursor="Hand"
                                                MouseLeftButtonUp="MonitorCard_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#1E3246"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1,1,1,2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                                                <Border Padding="5,2" CornerRadius="4" Margin="0,0,0,4"
                                                        HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1A4A7A"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPortrait}" Value="True">
                                                                    <Setter Property="Background" Value="#5A2A8A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding OrientationLabel}"
                                                               Foreground="White" FontSize="9"/>
                                                </Border>
                                                <TextBlock Text="{Binding Status}" FontSize="10" Margin="0,0,0,2">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#888"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Playing">
                                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Foreground="#777" FontSize="9" FontFamily="Consolas"
                                                           Text="{Binding NextChangeCountdown}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Switched views -->
                    <Grid x:Name="MonitorContentArea" Grid.Row="2">
                        <local:MonitorOverviewPanel DataContext="{Binding}">
                            <local:MonitorOverviewPanel.Style>
                                <Style TargetType="local:MonitorOverviewPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMonitor}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </local:MonitorOverviewPanel.Style>
                        </local:MonitorOverviewPanel>

                        <ContentControl Content="{Binding SelectedMonitor}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate>
                                    <local:MonitorPanel DataContext="{Binding}"/>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMonitor}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </Grid>

                    <local:GalleryView x:Name="GalleryPanel" Grid.Row="2"
                                       DataContext="{Binding Library.Gallery}"
                                       Visibility="Collapsed"/>

                    <local:GifPlayerView x:Name="GifPanel" Grid.Row="2"
                                         DataContext="{Binding GifPlayer}"
                                         Visibility="Collapsed"/>

                    <local:LockScreenView x:Name="LockScreenPanel" Grid.Row="2"
                                          DataContext="{Binding LockScreen}"
                                          Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
