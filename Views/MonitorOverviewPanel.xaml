<UserControl x:Class="BackgroundSlideShow.Views.MonitorOverviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BackgroundSlideShow"
             xmlns:vm="clr-namespace:BackgroundSlideShow.ViewModels"
             Background="#1E1E1E">

    <UserControl.Resources>
        <!-- Small action button style -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Configure button style -->
        <Style x:Key="ConfigureBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#1A3A5C"/>
            <Setter Property="Foreground" Value="#6DB3F2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#204A78"/>
                    <Setter Property="Foreground" Value="#90CAFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <TextBlock Text="MONITOR OVERVIEW" Foreground="#888" FontSize="11"
                       FontWeight="SemiBold" Margin="0,0,0,12"/>

            <ItemsControl x:Name="MonitorCards" ItemsSource="{Binding Monitors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
                        <Border Margin="0,0,0,12" Background="#252525"
                                BorderBrush="#444" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Card header -->
                                <Border Grid.Row="0" Background="#2A2A2A" Padding="10,8">
                                    <DockPanel>
                                        <!-- Left: name + orientation badge -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Orientation badge -->
                                            <Border Padding="5,2" CornerRadius="3" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1A4A7A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPortrait}" Value="True">
                                                                <Setter Property="Background" Value="#5A2A8A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding OrientationLabel}"
                                                           Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Right: status badge -->
                                        <Border DockPanel.Dock="Right" Padding="7,3" CornerRadius="10"
                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#444"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Playing">
                                                            <Setter Property="Background" Value="#1B5E20"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Background" Value="#E65100"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DockPanel>
                                </Border>

                                <!-- Card body -->
                                <Grid Grid.Row="1" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumbnail -->
                                    <Border Grid.Column="0" Background="#1A1A1A" Width="200" Height="113"
                                            HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <Grid>
                                            <!-- Placeholder when no image -->
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentImagePath}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="🖼" FontSize="22" Foreground="#444"
                                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                <TextBlock Text="No image" Foreground="#555" FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="Press Play to start" Foreground="#444" FontSize="9"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Image Source="{Binding CurrentImagePath,
                                                           Converter={x:Static local:ThumbnailConverter.Instance},
                                                           ConverterParameter=220}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Grid>
                                    </Border>

                                    <!-- Info + Controls -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">

                                        <!-- Timer row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="Next in  " Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding NextChangeCountdown}"
                                                       Foreground="White" FontFamily="Consolas" FontSize="15"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text="  |  " Foreground="#555" VerticalAlignment="Center"/>
                                            <TextBlock Text="Every " Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Config.IntervalSeconds,
                                                               Converter={x:Static local:IntervalConverter.Instance}}"
                                                       Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Image pool + resolution -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="Pool: " Foreground="#888" FontSize="11"/>
                                            <TextBlock Text="{Binding PoolDescription}" Foreground="#CCCCCC" FontSize="11"/>
                                            <TextBlock Text="  •  " Foreground="#555" FontSize="11"/>
                                            <TextBlock Foreground="#888" FontSize="11">
                                                <Run Text="{Binding Bounds.Width, StringFormat={}{0:0}}"/>
                                                <Run Text="×"/>
                                                <Run Text="{Binding Bounds.Height, StringFormat={}{0:0}}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Current image filename -->
                                        <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,10"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding CurrentImageName}"
                                                   ToolTip="{Binding CurrentImagePath}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentImageName}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Quick controls -->
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Play/Resume: context-aware — resumes from current position when paused -->
                                            <Button Margin="0,0,4,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                                                        <Setter Property="Content" Value="▶ Play"/>
                                                        <Setter Property="Command" Value="{Binding StartCommand}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                <Setter Property="Content" Value="▶ Resume"/>
                                                                <Setter Property="Command" Value="{Binding ResumeCommand}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="⏸"       Style="{StaticResource ActionBtn}"
                                                    Command="{Binding PauseCommand}"  Margin="0,0,4,0"
                                                    ToolTip="Pause"/>
                                            <Button Content="⏭"       Style="{StaticResource ActionBtn}"
                                                    Command="{Binding SkipCommand}"   Margin="0,0,4,0"
                                                    ToolTip="Skip to next image"/>
                                            <Button Content="■ Stop"  Style="{StaticResource ActionBtn}"
                                                    Command="{Binding StopCommand}"   Margin="0,0,12,0"/>
                                            <Button Content="⚙ Configure"
                                                    Style="{StaticResource ConfigureBtn}"
                                                    Command="{Binding DataContext.SelectMonitorCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>

                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
