<UserControl x:Class="BackgroundSlideShow.Views.MonitorOverviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:BackgroundSlideShow"
             xmlns:vm="clr-namespace:BackgroundSlideShow.ViewModels">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Monitor Overview"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <ItemsControl x:Name="MonitorCards" ItemsSource="{Binding Monitors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
                        <Border Margin="0,0,0,14" CornerRadius="8"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Card header -->
                                <Border Grid.Row="0" Padding="14,10" CornerRadius="8,8,0,0"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Orientation badge -->
                                            <Border Padding="6,2" CornerRadius="4" Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1A4A7A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPortrait}" Value="True">
                                                                <Setter Property="Background" Value="#5A2A8A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding OrientationLabel}"
                                                           Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Status badge -->
                                        <Border DockPanel.Dock="Right" Padding="8,4" CornerRadius="12"
                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#444"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Playing">
                                                            <Setter Property="Background" Value="#1B5E20"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Background" Value="#E65100"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DockPanel>
                                </Border>

                                <!-- Card body -->
                                <Grid Grid.Row="1" Margin="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumbnail -->
                                    <Border Grid.Column="0" Background="#1A1A1A" Width="200" Height="113"
                                            CornerRadius="6" HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <Border.Clip>
                                            <RectangleGeometry Rect="0,0,200,113" RadiusX="6" RadiusY="6"/>
                                        </Border.Clip>
                                        <Grid>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentImagePath}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <ui:SymbolIcon Symbol="Image24" FontSize="28" Foreground="#444" Margin="0,0,0,4"/>
                                                <TextBlock Text="No image" Foreground="#555" FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="Press Play to start" Foreground="#444" FontSize="9"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Image Source="{Binding CurrentImagePath,
                                                           Converter={x:Static local:ThumbnailConverter.Instance},
                                                           ConverterParameter=220}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Grid>
                                    </Border>

                                    <!-- Info + Controls -->
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0">

                                        <!-- Timer row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Next in  " Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding NextChangeCountdown}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       FontFamily="Consolas" FontSize="15"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text="  |  " Foreground="#555" VerticalAlignment="Center"/>
                                            <TextBlock Text="Every " Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Config.IntervalSeconds,
                                                               Converter={x:Static local:IntervalConverter.Instance}}"
                                                       Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Pool + resolution -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="Pool: " Foreground="#888" FontSize="11"/>
                                            <TextBlock Text="{Binding PoolDescription}" Foreground="#CCCCCC" FontSize="11"/>
                                            <TextBlock Text="  &#x2022;  " Foreground="#555" FontSize="11"/>
                                            <TextBlock Foreground="#888" FontSize="11">
                                                <Run Text="{Binding Bounds.Width, StringFormat={}{0:0}}"/>
                                                <Run Text="&#x00d7;"/>
                                                <Run Text="{Binding Bounds.Height, StringFormat={}{0:0}}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Current filename -->
                                        <TextBlock Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   FontSize="11" Margin="0,0,0,12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding CurrentImageName}"
                                                   ToolTip="{Binding CurrentImagePath}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentImageName}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Quick controls -->
                                        <StackPanel Orientation="Horizontal">
                                            <Button Margin="0,0,6,0" Padding="10,6">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Command" Value="{Binding StartCommand}"/>
                                                        <Setter Property="Content">
                                                            <Setter.Value>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <ui:SymbolIcon Symbol="Play24" FontSize="14" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="Play"/>
                                                                </StackPanel>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                <Setter Property="Command" Value="{Binding ResumeCommand}"/>
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <ui:SymbolIcon Symbol="Play24" FontSize="14" Margin="0,0,6,0"/>
                                                                            <TextBlock Text="Resume"/>
                                                                        </StackPanel>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Padding="8,6" Margin="0,0,6,0"
                                                    Command="{Binding PauseCommand}" ToolTip="Pause">
                                                <ui:SymbolIcon Symbol="Pause24" FontSize="14"/>
                                            </Button>
                                            <Button Padding="8,6" Margin="0,0,6,0"
                                                    Command="{Binding SkipCommand}" ToolTip="Skip to next image">
                                                <ui:SymbolIcon Symbol="Next24" FontSize="14"/>
                                            </Button>
                                            <Button Padding="8,6" Margin="0,0,14,0"
                                                    Command="{Binding StopCommand}" ToolTip="Stop">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Stop24" FontSize="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Stop"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Padding="10,6"
                                                    Command="{Binding DataContext.SelectMonitorCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#1A3A5C" Foreground="#6DB3F2">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Settings24" FontSize="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Configure"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>

                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
