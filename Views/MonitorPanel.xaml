<UserControl x:Class="BackgroundSlideShow.Views.MonitorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:BackgroundSlideShow.Models"
             xmlns:local="clr-namespace:BackgroundSlideShow"
             Background="#1E1E1E">

    <UserControl.Resources>
        <!-- Small pill-shaped preset button for interval quick-sets -->
        <Style x:Key="PresetBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Header -->
            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4">
                <Run Text="MONITOR — "/>
                <Run Text="{Binding DisplayName}"/>
            </TextBlock>

            <!-- Status badge -->
            <Border HorizontalAlignment="Left" Padding="8,3" CornerRadius="10" Margin="0,0,0,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#444"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Playing">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Paused">
                                <Setter Property="Background" Value="#E65100"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Status}" Foreground="White"
                           FontSize="11" FontWeight="SemiBold"/>
            </Border>

            <!-- Playback controls -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="Slideshow:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Margin="2" Padding="8,4">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="▶ Play"/>
                            <Setter Property="Command" Value="{Binding StartCommand}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                    <Setter Property="Content" Value="▶ Resume"/>
                                    <Setter Property="Command" Value="{Binding ResumeCommand}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="⏸ Pause" Command="{Binding PauseCommand}"  Margin="2" Padding="8,4"/>
                <Button Content="⏭ Skip"  Command="{Binding SkipCommand}"   Margin="2" Padding="8,4"/>
                <Button Content="■ Stop"  Command="{Binding StopCommand}"   Margin="2" Padding="8,4"/>
            </StackPanel>

            <!-- ── PLAYBACK ─────────────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="PLAYBACK" Foreground="#666" FontSize="10"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Rectangle Grid.Column="1" Height="1" Fill="#3A3A3A" VerticalAlignment="Center"/>
            </Grid>

            <!-- Interval row -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Interval:" Foreground="#888" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="10" Maximum="7200"
                        Value="{Binding Config.IntervalSeconds, Mode=TwoWay}"
                        VerticalAlignment="Center"
                        TickPlacement="BottomRight"
                        Ticks="30 60 300 600 1800 3600"/>
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="White" Margin="8,0,0,0"
                           Text="{Binding Config.IntervalSeconds,
                                  Converter={x:Static local:IntervalConverter.Instance}}"/>
            </Grid>

            <!-- Interval quick-set presets -->
            <WrapPanel Margin="90,0,0,10">
                <Button Content="30s"    Tag="30"   Click="IntervalPreset_Click"
                        Style="{StaticResource PresetBtn}" Margin="0,0,4,0"/>
                <Button Content="1 min"  Tag="60"   Click="IntervalPreset_Click"
                        Style="{StaticResource PresetBtn}" Margin="0,0,4,0"/>
                <Button Content="5 min"  Tag="300"  Click="IntervalPreset_Click"
                        Style="{StaticResource PresetBtn}" Margin="0,0,4,0"/>
                <Button Content="30 min" Tag="1800" Click="IntervalPreset_Click"
                        Style="{StaticResource PresetBtn}" Margin="0,0,4,0"/>
                <Button Content="1 hr"   Tag="3600" Click="IntervalPreset_Click"
                        Style="{StaticResource PresetBtn}" Margin="0,0,0,0"/>
            </WrapPanel>

            <!-- Order -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="Order:" Foreground="#888" VerticalAlignment="Center" Width="90"/>
                <RadioButton Content="Random"     Foreground="White" Margin="0,0,12,0"
                             IsChecked="{Binding Config.Order, Converter={StaticResource EnumBoolConverter},
                                         ConverterParameter=Random}"/>
                <RadioButton Content="Sequential" Foreground="White"
                             IsChecked="{Binding Config.Order, Converter={StaticResource EnumBoolConverter},
                                         ConverterParameter=Sequential}"/>
            </StackPanel>

            <!-- ── DISPLAY ──────────────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="DISPLAY" Foreground="#666" FontSize="10"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Rectangle Grid.Column="1" Height="1" Fill="#3A3A3A" VerticalAlignment="Center"/>
            </Grid>

            <!-- Fit mode -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="Fit Mode:" Foreground="#888" VerticalAlignment="Center" Width="90"/>
                <ComboBox SelectedValue="{Binding Config.FitMode, Mode=TwoWay}"
                          SelectedValuePath="Tag" MinWidth="120">
                    <ComboBoxItem Content="Fill"    Tag="{x:Static models:FitMode.Fill}"
                                  ToolTip="Scale image to fill the screen, cropping edges if needed"/>
                    <ComboBoxItem Content="Fit"     Tag="{x:Static models:FitMode.Fit}"
                                  ToolTip="Scale image to fit entirely on screen, with bars if needed"/>
                    <ComboBoxItem Content="Stretch" Tag="{x:Static models:FitMode.Stretch}"
                                  ToolTip="Stretch image to exactly fill the screen (may distort)"/>
                    <ComboBoxItem Content="Tile"    Tag="{x:Static models:FitMode.Tile}"
                                  ToolTip="Repeat the image as tiles across the screen"/>
                    <ComboBoxItem Content="Center"  Tag="{x:Static models:FitMode.Center}"
                                  ToolTip="Place image at its original size in the center of the screen"/>
                </ComboBox>
            </StackPanel>

            <!-- ── CONTENT ──────────────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CONTENT" Foreground="#666" FontSize="10"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Rectangle Grid.Column="1" Height="1" Fill="#3A3A3A" VerticalAlignment="Center"/>
            </Grid>

            <!-- Image Pool -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Image Pool:" Foreground="#888" VerticalAlignment="Top"
                           Width="90" Margin="0,3,0,0"/>
                <StackPanel>
                    <RadioButton Content="All images" Foreground="White" Margin="0,0,0,5"
                                 IsChecked="{Binding Config.ImagePoolMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=All}"
                                 ToolTip="Show any image regardless of orientation"/>
                    <RadioButton Content="Landscape only" Foreground="White" Margin="0,0,0,5"
                                 IsChecked="{Binding Config.ImagePoolMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=Landscape}"
                                 ToolTip="Only show images that are wider than they are tall"/>
                    <RadioButton Content="Portrait only" Foreground="White" Margin="0,0,0,5"
                                 IsChecked="{Binding Config.ImagePoolMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=Portrait}"
                                 ToolTip="Only show images that are taller than they are wide"/>
                    <RadioButton Content="Smart match" Foreground="White"
                                 IsChecked="{Binding Config.ImagePoolMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=Smart}"
                                 ToolTip="Automatically prefer images that match this monitor's orientation"/>
                    <TextBlock Text="Auto-prefers images matching this monitor's orientation."
                               Foreground="#555" FontSize="9" Margin="18,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- Folder source -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Folder Source:" Foreground="#888" VerticalAlignment="Top"
                           Width="90" Margin="0,3,0,0"/>
                <StackPanel>
                    <RadioButton Content="All folders" Foreground="White" Margin="0,0,0,4"
                                 IsChecked="{Binding Config.FolderAssignmentMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=All}"
                                 ToolTip="Use images from every enabled library folder"/>
                    <RadioButton Content="Selected folders" Foreground="White" Margin="0,0,0,4"
                                 IsChecked="{Binding Config.FolderAssignmentMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=Selected}"
                                 ToolTip="Only use images from the folders checked below"/>

                    <!-- Folder checklist — shown only when Selected is active -->
                    <Border Margin="0,2,0,0" Padding="6,4" Background="#2A2A2A" CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Config.FolderAssignmentMode}"
                                                 Value="{x:Static models:FolderAssignmentMode.Selected}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ItemsControl ItemsSource="{Binding FolderAssignments}" MaxHeight="160">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsAssigned, Mode=TwoWay}"
                                              Foreground="White" Margin="0,2"
                                              ToolTip="{Binding Folder.Path}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </StackPanel>

            <Separator Background="#3A3A3A" Margin="0,12,0,12"/>

            <!-- Current image -->
            <TextBlock Text="Current:" Foreground="#888" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding CurrentImagePath}" Foreground="White" FontSize="11"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>

            <!-- Thumbnail -->
            <Border Width="280" Height="158" Background="#2D2D2D"
                    HorizontalAlignment="Left" Margin="0,0,0,8">
                <Image Source="{Binding CurrentImagePath,
                               Converter={x:Static local:ThumbnailConverter.Instance},
                               ConverterParameter=280}"
                       Stretch="Uniform"/>
            </Border>

            <!-- Countdown -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Next in: " Foreground="#888"/>
                <TextBlock Text="{Binding NextChangeCountdown}" Foreground="White" FontFamily="Consolas"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
