<UserControl x:Class="BackgroundSlideShow.Views.MonitorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:BackgroundSlideShow.Models"
             xmlns:local="clr-namespace:BackgroundSlideShow">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header -->
            <TextBlock FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,6">
                <Run Text="Monitor &#x2014; "/>
                <Run Text="{Binding DisplayName}"/>
            </TextBlock>

            <!-- Status badge -->
            <Border HorizontalAlignment="Left" Padding="10,4" CornerRadius="12" Margin="0,0,0,16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#444"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Playing">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Paused">
                                <Setter Property="Background" Value="#E65100"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Status}" Foreground="White"
                           FontSize="11" FontWeight="SemiBold"/>
            </Border>

            <!-- Playback controls -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Slideshow:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Margin="0,0,4,0" Padding="10,6">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Command" Value="{Binding StartCommand}"/>
                            <Setter Property="Content">
                                <Setter.Value>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Play24" FontSize="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="Play"/>
                                    </StackPanel>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                    <Setter Property="Command" Value="{Binding ResumeCommand}"/>
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Play24" FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Resume"/>
                                            </StackPanel>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding PauseCommand}" Margin="0,0,4,0" Padding="8,6" ToolTip="Pause">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Pause24" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Pause"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding SkipCommand}" Margin="0,0,4,0" Padding="8,6" ToolTip="Skip">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Next24" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Skip"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding StopCommand}" Padding="8,6">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Stop24" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Stop"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- ── PLAYBACK ──────────────────────────────────────────────── -->
            <TextBlock Text="PLAYBACK" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <!-- Interval -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Interval:" Foreground="#888" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="10" Maximum="7200"
                        Value="{Binding Config.IntervalSeconds, Mode=TwoWay}"
                        VerticalAlignment="Center"
                        TickPlacement="BottomRight"
                        Ticks="30 60 300 600 1800 3600"/>
                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="10,0,0,0"
                           Text="{Binding Config.IntervalSeconds,
                                  Converter={x:Static local:IntervalConverter.Instance}}"/>
            </Grid>

            <!-- Presets -->
            <WrapPanel Margin="90,0,0,14">
                <Button Content="30s"    Tag="30"   Click="IntervalPreset_Click" Padding="8,3" Margin="0,0,4,0" FontSize="10"/>
                <Button Content="1 min"  Tag="60"   Click="IntervalPreset_Click" Padding="8,3" Margin="0,0,4,0" FontSize="10"/>
                <Button Content="5 min"  Tag="300"  Click="IntervalPreset_Click" Padding="8,3" Margin="0,0,4,0" FontSize="10"/>
                <Button Content="30 min" Tag="1800" Click="IntervalPreset_Click" Padding="8,3" Margin="0,0,4,0" FontSize="10"/>
                <Button Content="1 hr"   Tag="3600" Click="IntervalPreset_Click" Padding="8,3" FontSize="10"/>
            </WrapPanel>

            <!-- Order -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Order:" Foreground="#888" VerticalAlignment="Center" Width="90"/>
                <RadioButton Content="Random" Margin="0,0,16,0"
                             IsChecked="{Binding Config.Order, Converter={StaticResource EnumBoolConverter},
                                         ConverterParameter=Random}"/>
                <RadioButton Content="Sequential"
                             IsChecked="{Binding Config.Order, Converter={StaticResource EnumBoolConverter},
                                         ConverterParameter=Sequential}"/>
            </StackPanel>

            <!-- ── DISPLAY ───────────────────────────────────────────────── -->
            <TextBlock Text="DISPLAY" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Fit Mode:" Foreground="#888" VerticalAlignment="Center" Width="90"/>
                <ComboBox SelectedValue="{Binding Config.FitMode, Mode=TwoWay}"
                          SelectedValuePath="Tag" MinWidth="140">
                    <ComboBoxItem Content="Fill"    Tag="{x:Static models:FitMode.Fill}"/>
                    <ComboBoxItem Content="Fit"     Tag="{x:Static models:FitMode.Fit}"/>
                    <ComboBoxItem Content="Stretch" Tag="{x:Static models:FitMode.Stretch}"/>
                    <ComboBoxItem Content="Tile"    Tag="{x:Static models:FitMode.Tile}"/>
                    <ComboBoxItem Content="Center"  Tag="{x:Static models:FitMode.Center}"/>
                </ComboBox>
            </StackPanel>

            <!-- Collage -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Width="90"/>
                <ui:ToggleSwitch Content="Enable collages (2&#x2013;6 photos per wallpaper)"
                                 IsChecked="{Binding Config.CollageEnabled, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20"
                        Visibility="{Binding Config.CollageEnabled, Converter={StaticResource BoolToVis}}">
                <TextBlock Width="90"/>
                <TextBlock Text="Frequency:" Foreground="#888" Width="72" VerticalAlignment="Center"/>
                <Slider Minimum="10" Maximum="100" SmallChange="10" LargeChange="20"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        Value="{Binding Config.CollageChance, Mode=TwoWay}"
                        Width="130" VerticalAlignment="Center"/>
                <TextBlock Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Run Text="{Binding Config.CollageChance, Mode=OneWay}"/><Run Text="%"/>
                </TextBlock>
            </StackPanel>

            <!-- ── CONTENT ───────────────────────────────────────────────── -->
            <TextBlock Text="CONTENT" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <!-- Image Pool -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="Image Pool:" Foreground="#888" VerticalAlignment="Top"
                           Width="90" Margin="0,4,0,0"/>
                <StackPanel>
                    <RadioButton Content="All images" Margin="0,0,0,6"
                                 IsChecked="{Binding Config.ImagePoolMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=All}"/>
                    <RadioButton Content="Landscape only" Margin="0,0,0,6"
                                 IsChecked="{Binding Config.ImagePoolMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=Landscape}"/>
                    <RadioButton Content="Portrait only" Margin="0,0,0,6"
                                 IsChecked="{Binding Config.ImagePoolMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=Portrait}"/>
                    <RadioButton Content="Smart match"
                                 IsChecked="{Binding Config.ImagePoolMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=Smart}"/>
                    <TextBlock Text="Auto-prefers images matching this monitor's orientation."
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               FontSize="9" Margin="22,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- Folder source -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Folder Source:" Foreground="#888" VerticalAlignment="Top"
                           Width="90" Margin="0,4,0,0"/>
                <StackPanel>
                    <RadioButton Content="All folders" Margin="0,0,0,6"
                                 IsChecked="{Binding Config.FolderAssignmentMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=All}"/>
                    <RadioButton Content="Selected folders" Margin="0,0,0,6"
                                 IsChecked="{Binding Config.FolderAssignmentMode, Mode=TwoWay,
                                             Converter={StaticResource EnumBoolConverter},
                                             ConverterParameter=Selected}"/>

                    <Border Margin="0,2,0,0" Padding="8,6" CornerRadius="6"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Config.FolderAssignmentMode}"
                                                 Value="{x:Static models:FolderAssignmentMode.Selected}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ItemsControl ItemsSource="{Binding FolderAssignments}" MaxHeight="160">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsAssigned, Mode=TwoWay}"
                                              Margin="0,3" ToolTip="{Binding Folder.Path}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </StackPanel>

            <Separator Margin="0,16,0,16"/>

            <!-- Current image -->
            <TextBlock Text="Current:" Foreground="#888" Margin="0,0,0,6"/>
            <TextBlock Text="{Binding CurrentImagePath}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,0,0,10"/>

            <Border Width="280" Height="158" CornerRadius="6"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    HorizontalAlignment="Left" Margin="0,0,0,10">
                <Border.Clip>
                    <RectangleGeometry Rect="0,0,280,158" RadiusX="6" RadiusY="6"/>
                </Border.Clip>
                <Image Source="{Binding CurrentImagePath,
                               Converter={x:Static local:ThumbnailConverter.Instance},
                               ConverterParameter=280}"
                       Stretch="Uniform"/>
            </Border>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Next in: " Foreground="#888"/>
                <TextBlock Text="{Binding NextChangeCountdown}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontFamily="Consolas"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
