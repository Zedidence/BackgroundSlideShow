<UserControl x:Class="BackgroundSlideShow.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:BackgroundSlideShow"
             xmlns:vm="clr-namespace:BackgroundSlideShow.ViewModels"
             AllowDrop="True"
             Drop="LibraryView_Drop"
             DragOver="LibraryView_DragOver">

    <DockPanel>

        <!-- Header: Add + Refresh + summary text -->
        <StackPanel DockPanel.Dock="Top" Margin="10,10,10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="0,0,4,0" Padding="8,5"
                        Command="{Binding AddFolderCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add24" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Add" FontSize="11"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Margin="0,0,4,0" Padding="8,5"
                        Command="{Binding ScanNowCommand}"
                        IsEnabled="{Binding IsScanning, Converter={x:Static local:BoolNegationConverter.Instance}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Refresh" FontSize="11"/>
                    </StackPanel>
                </Button>

                <!-- Remove All — de-emphasised: icon-only, tucked to the right -->
                <Button Grid.Column="2" Padding="7,5"
                        ToolTip="Remove all folders from the library"
                        Click="RemoveAll_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#666">
                    <ui:SymbolIcon Symbol="DeleteDismiss24" FontSize="14"/>
                </Button>
            </Grid>

            <!-- Summary: "4 folders · 1,234 images" -->
            <TextBlock Text="{Binding SummaryText}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="10" Margin="0,5,0,0"
                       TextTrimming="CharacterEllipsis">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SummaryText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Scan status (only shown while scanning or just after) -->
            <TextBlock Text="{Binding ScanStatus}"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" Margin="0,3,0,0" TextTrimming="CharacterEllipsis">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ScanStatus}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Scrollable folder list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding Folders}" Margin="10,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FolderItemViewModel}">
                            <Border Margin="0,3" Padding="8,7" CornerRadius="6"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <DockPanel LastChildFill="True">

                                    <!-- Remove button (always full opacity, top-right) -->
                                    <Button DockPanel.Dock="Right" Padding="4,2" Margin="6,0,0,0"
                                            VerticalAlignment="Top" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding DataContext.RemoveFolderCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}">
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" Foreground="#666"/>
                                    </Button>

                                    <!-- Checkbox stays outside the dimmed region so it remains
                                         fully visible and clickable even when the folder is disabled.
                                         (WPF Opacity cascades; you cannot override it on a child.) -->
                                    <CheckBox DockPanel.Dock="Left"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Top" Margin="0,1,7,0"
                                              ToolTip="Include this folder in the slideshow"/>

                                    <!-- Text content: dims when the folder is disabled -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter Property="Opacity" Value="0.45"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <!-- Folder name -->
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Path}"/>

                                        <!-- Parent path hint — hidden when empty (root-level folder) -->
                                        <TextBlock Text="{Binding ParentPathHint}"
                                                   Margin="0,1,0,0" FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Path}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ParentPathHint}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Image count · last scanned -->
                                        <TextBlock Margin="0,3,0,0" FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                            <Run Text="{Binding ImageCount, StringFormat='{}{0:N0} images', Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding LastScanned,
                                                       Converter={x:Static local:RelativeTimeConverter.Instance},
                                                       Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty-state hint -->
                <StackPanel Margin="10,24" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Folders.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="28" Foreground="#555" Margin="0,0,0,8"
                                   HorizontalAlignment="Center"/>
                    <TextBlock Text="No folders added yet."
                               Foreground="#888" FontSize="12" TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Click Add or drag folders here."
                               Foreground="#666" FontSize="11" TextAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
