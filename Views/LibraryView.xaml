<UserControl x:Class="BackgroundSlideShow.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:BackgroundSlideShow"
             xmlns:vm="clr-namespace:BackgroundSlideShow.ViewModels"
             AllowDrop="True"
             Drop="LibraryView_Drop"
             DragOver="LibraryView_DragOver">

    <UserControl.Resources>
        <local:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
    </UserControl.Resources>

    <DockPanel>

        <!-- Action buttons + scan status -->
        <StackPanel DockPanel.Dock="Top" Margin="10,10,10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Margin="0,0,4,0" Padding="8,5"
                        Command="{Binding AddFolderCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add24" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Add" FontSize="11"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Margin="0,0,4,0" Padding="8,5"
                        Command="{Binding ScanNowCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Refresh" FontSize="11"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Padding="8,5"
                        ToolTip="Remove all folders from the library"
                        Click="RemoveAll_Click"
                        Background="#3A1A1A" Foreground="#CC6666" BorderBrush="#5C2A2A">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                </Button>
            </Grid>
            <TextBlock Text="{Binding ScanStatus}"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Scrollable folder list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding Folders}" Margin="10,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FolderItemViewModel}">
                            <Border Margin="0,3" Padding="8,6" CornerRadius="6"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <DockPanel LastChildFill="True">

                                    <!-- Remove button -->
                                    <Button DockPanel.Dock="Right" Padding="4,2" Margin="6,0,0,0"
                                            VerticalAlignment="Top" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding DataContext.RemoveFolderCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}">
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" Foreground="#888"/>
                                    </Button>

                                    <StackPanel>
                                        <DockPanel>
                                            <CheckBox DockPanel.Dock="Left"
                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                                      ToolTip="Include this folder in the slideshow"/>
                                            <ui:SymbolIcon Symbol="Folder24" FontSize="14"
                                                           Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" ToolTip="{Binding Path}"/>
                                        </DockPanel>

                                        <TextBlock Margin="26,2,0,0" FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                            <Run Text="{Binding ImageCount, StringFormat='{}{0:N0} images', Mode=OneWay}"/>
                                            <Run Text=" | Scanned: "/>
                                            <Run Text="{Binding LastScanned,
                                                       Converter={StaticResource RelativeTimeConverter},
                                                       Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty-state hint -->
                <StackPanel Margin="10,24" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Folders.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="28" Foreground="#555" Margin="0,0,0,8"
                                   HorizontalAlignment="Center"/>
                    <TextBlock Text="No folders added yet."
                               Foreground="#888" FontSize="12" TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Click Add or drag folders here."
                               Foreground="#666" FontSize="11" TextAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
