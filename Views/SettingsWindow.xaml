<Window x:Class="BackgroundSlideShow.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <StackPanel Margin="20">
        <TextBlock Text="Settings" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- Launch on startup -->
        <CheckBox x:Name="ChkLaunchOnStartup"
                  Content="Launch at Windows startup" Foreground="White" Margin="0,0,0,8"/>

        <Separator Background="#3A3A3A" Margin="0,8,0,12"/>

        <!-- Transitions -->
        <TextBlock Text="Transitions" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <CheckBox x:Name="ChkTransitionsEnabled"
                  Content="Fade between wallpapers" Foreground="White" Margin="0,0,0,10"
                  ToolTip="Crossfade the old wallpaper out when a new one is set"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderTransitionDuration"
                    Minimum="200" Maximum="1500" TickFrequency="100"
                    IsSnapToTickEnabled="True"
                    ToolTip="Fade duration in milliseconds"/>
            <TextBlock Grid.Column="1" Margin="6,0,0,0" Foreground="#AAA" FontSize="11"
                       VerticalAlignment="Center"
                       Text="{Binding ElementName=SliderTransitionDuration,
                                      Path=Value, StringFormat='{}{0:0}ms'}"/>
        </Grid>
        <TextBlock Text="Fade duration" Foreground="#666" FontSize="10" Margin="0,0,0,4"/>

        <Separator Background="#3A3A3A" Margin="0,12,0,12"/>

        <Button Content="Close" HorizontalAlignment="Right" Padding="16,6"
                Click="Close_Click"/>
    </StackPanel>
</Window>
