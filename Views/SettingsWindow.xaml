<ui:FluentWindow x:Class="BackgroundSlideShow.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings"
        Width="460" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <ui:TitleBar Title="Settings" Grid.Row="0"/>

        <StackPanel Margin="24,48,24,24">

            <TextBlock Text="General" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

            <!-- Launch on startup -->
            <ui:ToggleSwitch x:Name="ChkLaunchOnStartup"
                             Content="Launch at Windows startup" Margin="0,0,0,12"/>

            <Separator Margin="0,4,0,16"/>

            <TextBlock Text="Transitions" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

            <ui:ToggleSwitch x:Name="ChkTransitionsEnabled"
                             Content="Fade between wallpapers" Margin="0,0,0,12"
                             ToolTip="Crossfade the old wallpaper out when a new one is set"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SliderTransitionDuration"
                        Minimum="200" Maximum="1500" TickFrequency="100"
                        IsSnapToTickEnabled="True"
                        ToolTip="Fade duration in milliseconds"/>
                <TextBlock Grid.Column="1" Margin="8,0,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="11" VerticalAlignment="Center"
                           Text="{Binding ElementName=SliderTransitionDuration,
                                          Path=Value, StringFormat='{}{0:0} ms'}"/>
            </Grid>
            <TextBlock Text="Fade duration"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" Margin="0,0,0,8"/>

            <Separator Margin="0,8,0,16"/>

            <TextBlock Text="Data" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <DockPanel>
                <Button DockPanel.Dock="Left" Padding="14,8"
                        Click="Reset_Click" ToolTip="Delete the image library, thumbnail cache, and settings. The app will close."
                        Background="#3A1A1A" Foreground="#CC6666" BorderBrush="#5C2A2A">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Delete24" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Reset All Data"/>
                    </StackPanel>
                </Button>
                <TextBlock Margin="12,0,0,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           FontSize="10" VerticalAlignment="Center" TextWrapping="Wrap"
                           Text="Clears library, cache &amp; settings. Your image files are untouched."/>
            </DockPanel>

            <Separator Margin="0,16,0,16"/>

            <Button Content="Close" HorizontalAlignment="Right" Padding="20,8"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
