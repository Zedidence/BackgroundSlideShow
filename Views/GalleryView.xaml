<UserControl x:Class="BackgroundSlideShow.Views.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BackgroundSlideShow"
             xmlns:vm="clr-namespace:BackgroundSlideShow.ViewModels"
             Background="#252525">

    <UserControl.Resources>
        <!-- Proxy to pipe LibraryViewModel into ContextMenus and ItemsPanelTemplates -->
        <local:BindingProxy x:Key="ViewModelProxy" Data="{Binding}"/>

        <!-- Shared nav/action button style for preview overlay buttons -->
        <Style x:Key="PreviewNavBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Root Grid lets the preview overlay sit above everything else -->
    <Grid>

        <!-- ── Main content ──────────────────────────────────────────── -->
        <DockPanel>

            <!-- Filters + Search + Sort + Size + count summary -->
            <StackPanel DockPanel.Dock="Top" Margin="8,8,8,4">

                <!-- Monitor pool filter label + combo -->
                <TextBlock Text="Monitor pool:" Foreground="#888" FontSize="10" Margin="0,0,0,2"/>
                <ComboBox Margin="0,0,0,6"
                          ItemsSource="{Binding GalleryMonitorOptions}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedGalleryMonitorFilter, Mode=TwoWay}"
                          ToolTip="Filter images to those eligible for a specific monitor's pool"/>

                <!-- Search box -->
                <Grid Margin="0,0,0,4">
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#CCC" Background="#1A1A1A"
                             BorderBrush="#444" BorderThickness="1" Padding="4,3"/>
                    <TextBlock Text="🔍 Search by filename…" Foreground="#555" FontSize="11"
                               Margin="6,3,0,0" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Orientation filter + Sort -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Margin="0,0,2,0"
                              SelectedValue="{Binding OrientationFilter, Mode=TwoWay}"
                              ToolTip="Filter by orientation">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Landscape"/>
                        <ComboBoxItem Content="Portrait"/>
                    </ComboBox>
                    <ComboBox Grid.Column="1" Margin="2,0,0,0"
                              SelectedValue="{Binding SortOrder, Mode=TwoWay}"
                              ToolTip="Sort order">
                        <ComboBoxItem Content="Default"/>
                        <ComboBoxItem Content="Name A→Z"/>
                        <ComboBoxItem Content="Name Z→A"/>
                        <ComboBoxItem Content="Date Modified"/>
                        <ComboBoxItem Content="File Size"/>
                    </ComboBox>
                </Grid>

                <!-- Thumbnail size slider -->
                <DockPanel Margin="0,0,0,4">
                    <TextBlock DockPanel.Dock="Right" Width="34" TextAlignment="Right"
                               Foreground="#666" FontSize="10" VerticalAlignment="Center"
                               Text="{Binding ThumbnailSize, StringFormat='{}{0}px'}"/>
                    <Slider Value="{Binding ThumbnailSize, Mode=TwoWay}"
                            Minimum="48" Maximum="200" TickFrequency="8"
                            IsSnapToTickEnabled="True"
                            ToolTip="Thumbnail size"/>
                </DockPanel>

                <!-- Count summary + excluded badge row -->
                <DockPanel Margin="0,2,0,0">
                    <!-- Excluded count chip (right-aligned) -->
                    <Border DockPanel.Dock="Right" Padding="6,2" CornerRadius="3"
                            Background="#3A1A1A" BorderBrush="#5C2A2A" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowExcludedBadge}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ExcludedBadgeText}"
                                   Foreground="#CC6666" FontSize="10"
                                   ToolTip="Right-click an image to include or exclude it"/>
                    </Border>
                    <!-- Count summary -->
                    <TextBlock Text="{Binding CountSummaryText}"
                               Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                </DockPanel>

            </StackPanel>

            <!-- ── Empty state: library has no images ── -->
            <Grid DockPanel.Dock="Top">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLibraryEmpty}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,32">
                    <TextBlock Text="📂" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="No images in your library" Foreground="#888"
                               FontSize="13" TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Add a folder in the sidebar to get started."
                               Foreground="#555" FontSize="11" TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- ── Empty state: filters return nothing ── -->
            <Grid DockPanel.Dock="Top">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFilterEmpty}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,24">
                    <TextBlock Text="No images match your filters." Foreground="#888"
                               FontSize="13" TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Try adjusting the search, orientation, or monitor filter."
                               Foreground="#555" FontSize="11" TextAlignment="Center" Margin="0,0,0,10"/>
                    <Button Content="Clear Filters" HorizontalAlignment="Center"
                            Command="{Binding ClearFiltersCommand}"
                            Padding="12,5" Background="#2D2D2D"
                            Foreground="#AAAAAA" BorderBrush="#555"/>
                </StackPanel>
            </Grid>

            <!-- Virtualized image grid -->
            <ListBox ItemsSource="{Binding Images}"
                     SelectedItem="{Binding SelectedImage, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     x:Name="ImageListBox">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <local:VirtualizingWrapPanel
                            ItemWidth="{Binding Data.ThumbnailSize, Source={StaticResource ViewModelProxy}}"
                            ItemHeight="{Binding Data.ThumbnailSize, Source={StaticResource ViewModelProxy}}"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="SelectionBorder"
                                            BorderThickness="2" BorderBrush="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="SelectionBorder"
                                                    Property="BorderBrush" Value="#5B9BD5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="{Binding Data.ThumbnailSize, Source={StaticResource ViewModelProxy}}"
                              Height="{Binding Data.ThumbnailSize, Source={StaticResource ViewModelProxy}}"
                              Cursor="Hand">
                            <!-- Thumbnail image -->
                            <Image Margin="2" Stretch="UniformToFill"
                                   Width="{Binding Data.ThumbnailImageSize, Source={StaticResource ViewModelProxy}}"
                                   Height="{Binding Data.ThumbnailImageSize, Source={StaticResource ViewModelProxy}}"
                                   ToolTip="{Binding FilePath}">
                                <Image.Source>
                                    <MultiBinding Converter="{x:Static local:ThumbnailMultiConverter.Instance}">
                                        <Binding Path="FilePath"/>
                                        <Binding Path="Data.ThumbnailSize" Source="{StaticResource ViewModelProxy}"/>
                                    </MultiBinding>
                                </Image.Source>
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExcluded}" Value="True">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                                <Image.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open file location"
                                                  Click="ContextMenu_OpenFileLocation"
                                                  Tag="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Click="ContextMenu_ToggleExclude"
                                                  Tag="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Exclude from slideshow"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsExcluded,
                                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                             Value="True">
                                                                    <Setter Property="Text" Value="Include in slideshow"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Image.ContextMenu>
                            </Image>

                            <!-- Excluded indicator (✕ badge) -->
                            <Border Background="#99000000" IsHitTestVisible="False" Margin="2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExcluded}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="✕" Foreground="#FF6B6B" FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           ToolTip="Excluded — right-click to include in slideshow"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </DockPanel>

        <!-- ── Preview overlay ───────────────────────────────────────────── -->
        <Grid x:Name="PreviewOverlayGrid" Background="#CC000000"
              MouseDown="PreviewOverlay_MouseDown"
              IsVisibleChanged="PreviewOverlay_IsVisibleChanged"
              Focusable="True"
              KeyDown="PreviewOverlay_KeyDown">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPreviewVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Background="#1E1E1E" CornerRadius="8" Padding="16" Margin="12"
                    MaxWidth="420" MaxHeight="620"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MouseDown="PreviewContent_MouseDown">
                <StackPanel>
                    <!-- Header: filename + close -->
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="✕" Padding="6,2"
                                Command="{Binding ClosePreviewCommand}"
                                Background="Transparent" BorderBrush="#555"
                                Foreground="#CCC" Cursor="Hand"/>
                        <TextBlock Text="{Binding PreviewFileName}"
                                   Foreground="#EEE" FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Large preview image -->
                    <Border Background="#111" Margin="0,0,0,8" MaxHeight="300">
                        <Image MaxWidth="388" MaxHeight="300" Stretch="Uniform"
                               Source="{Binding SelectedImage.FilePath,
                                        Converter={x:Static local:ThumbnailConverter.Instance},
                                        ConverterParameter=388}"/>
                    </Border>

                    <!-- Navigation row: prev / position / next -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="◀ Prev"
                                Style="{StaticResource PreviewNavBtn}"
                                Command="{Binding NavigatePreviousCommand}"
                                ToolTip="Previous image (Left arrow key)"/>
                        <TextBlock Grid.Column="1" Text="{Binding PreviewPositionText}"
                                   Foreground="#666" FontSize="10" FontFamily="Consolas"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="Next ▶"
                                Style="{StaticResource PreviewNavBtn}"
                                Command="{Binding NavigateNextCommand}"
                                ToolTip="Next image (Right arrow key)"/>
                    </Grid>

                    <!-- Metadata grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Dimensions:" Foreground="#888" FontSize="11" Margin="0,0,8,3"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewDimensions}" Foreground="#CCC" FontSize="11" Margin="0,0,0,3"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="File size:" Foreground="#888" FontSize="11" Margin="0,0,8,3"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewFileSize}" Foreground="#CCC" FontSize="11" Margin="0,0,0,3"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Path:" Foreground="#888" FontSize="11" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewPath}"
                                   Foreground="#AAA" FontSize="10" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
