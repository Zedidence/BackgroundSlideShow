<UserControl x:Class="BackgroundSlideShow.Views.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:BackgroundSlideShow"
             xmlns:vm="clr-namespace:BackgroundSlideShow.ViewModels">

    <UserControl.Resources>
        <local:BindingProxy x:Key="ViewModelProxy" Data="{Binding}"/>
    </UserControl.Resources>

    <!-- Root Grid lets the preview overlay sit above everything else -->
    <Grid>

        <!-- ── Main content ──────────────────────────────────────────── -->
        <DockPanel>

            <!-- Filters + Search + Sort + Size + count summary -->
            <StackPanel DockPanel.Dock="Top" Margin="10,10,10,6">

                <!-- Monitor pool filter -->
                <TextBlock Text="Monitor pool:"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           FontSize="10" Margin="0,0,0,3"/>
                <ComboBox Margin="0,0,0,8"
                          ItemsSource="{Binding GalleryMonitorOptions}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedGalleryMonitorFilter, Mode=TwoWay}"
                          ToolTip="Filter images to those eligible for a specific monitor's pool"/>

                <!-- Search box -->
                <Grid Margin="0,0,0,6">
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,5"/>
                    <StackPanel Orientation="Horizontal" Margin="8,5,0,0" IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ui:SymbolIcon Symbol="Search24" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,6,0"/>
                        <TextBlock Text="Search by filename..."
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Orientation + Sort -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Margin="0,0,3,0"
                              SelectedValue="{Binding OrientationFilter, Mode=TwoWay}"
                              ToolTip="Filter by orientation">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Landscape"/>
                        <ComboBoxItem Content="Portrait"/>
                    </ComboBox>
                    <ComboBox Grid.Column="1" Margin="3,0,0,0"
                              SelectedValue="{Binding SortOrder, Mode=TwoWay}"
                              ToolTip="Sort order">
                        <ComboBoxItem Content="Default"/>
                        <ComboBoxItem Content="Name A&#x2192;Z"/>
                        <ComboBoxItem Content="Name Z&#x2192;A"/>
                        <ComboBoxItem Content="Date Modified"/>
                        <ComboBoxItem Content="File Size"/>
                    </ComboBox>
                </Grid>

                <!-- Thumbnail size slider -->
                <DockPanel Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Right" Width="34" TextAlignment="Right"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               FontSize="10" VerticalAlignment="Center"
                               Text="{Binding ThumbnailSize, StringFormat='{}{0}px'}"/>
                    <Slider Value="{Binding ThumbnailSize, Mode=TwoWay}"
                            Minimum="48" Maximum="200" TickFrequency="8"
                            IsSnapToTickEnabled="True" ToolTip="Thumbnail size"/>
                </DockPanel>

                <!-- Count summary + excluded badge -->
                <DockPanel Margin="0,2,0,0">
                    <Border DockPanel.Dock="Right" Padding="8,3" CornerRadius="4"
                            Background="#3A1A1A" BorderBrush="#5C2A2A" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowExcludedBadge}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ExcludedBadgeText}"
                                   Foreground="#CC6666" FontSize="10"/>
                    </Border>
                    <TextBlock Text="{Binding CountSummaryText}"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               FontSize="10" VerticalAlignment="Center"/>
                </DockPanel>

            </StackPanel>

            <!-- Loading indicator -->
            <ui:ProgressRing DockPanel.Dock="Top" Width="20" Height="20"
                             IsIndeterminate="True" HorizontalAlignment="Center" Margin="0,4">
                <ui:ProgressRing.Style>
                    <Style TargetType="ui:ProgressRing">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:ProgressRing.Style>
            </ui:ProgressRing>

            <!-- Empty state: library has no images -->
            <Grid DockPanel.Dock="Top">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLibraryEmpty}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,32">
                    <ui:SymbolIcon Symbol="Image24" FontSize="32" Foreground="#555"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="No images in your library" Foreground="#888"
                               FontSize="13" TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Add a folder in the sidebar to get started."
                               Foreground="#555" FontSize="11" TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Empty state: filters return nothing -->
            <Grid DockPanel.Dock="Top">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFilterEmpty}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,24">
                    <TextBlock Text="No images match your filters." Foreground="#888"
                               FontSize="13" TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Try adjusting the search, orientation, or monitor filter."
                               Foreground="#555" FontSize="11" TextAlignment="Center" Margin="0,0,0,12"/>
                    <Button Content="Clear Filters" HorizontalAlignment="Center"
                            Command="{Binding ClearFiltersCommand}" Padding="14,6"/>
                </StackPanel>
            </Grid>

            <!-- Virtualized image grid -->
            <ListBox ItemsSource="{Binding Images}"
                     SelectedItem="{Binding SelectedImage, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     x:Name="ImageListBox">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <local:VirtualizingWrapPanel
                            ItemWidth="{Binding Data.ThumbnailSize, Source={StaticResource ViewModelProxy}}"
                            ItemHeight="{Binding Data.ThumbnailSize, Source={StaticResource ViewModelProxy}}"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="SelectionBorder"
                                            BorderThickness="2" BorderBrush="Transparent"
                                            CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="SelectionBorder"
                                                    Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        </Trigger>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SelectionBorder"
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                        To="1.06" Duration="0:0:0.12">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetName="SelectionBorder"
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                        To="1.06" Duration="0:0:0.12">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SelectionBorder"
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                        To="1.0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetName="SelectionBorder"
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                        To="1.0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="{Binding Data.ThumbnailSize, Source={StaticResource ViewModelProxy}}"
                              Height="{Binding Data.ThumbnailSize, Source={StaticResource ViewModelProxy}}"
                              Background="#1A1A1A" Cursor="Hand">
                            <Image Margin="2" Stretch="UniformToFill"
                                   Width="{Binding Data.ThumbnailImageSize, Source={StaticResource ViewModelProxy}}"
                                   Height="{Binding Data.ThumbnailImageSize, Source={StaticResource ViewModelProxy}}"
                                   local:AsyncThumbnailLoader.SourcePath="{Binding FilePath}"
                                   ToolTip="{Binding FilePath}"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExcluded}" Value="True">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                                <Image.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open file location"
                                                  Click="ContextMenu_OpenFileLocation"
                                                  Tag="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Click="ContextMenu_ToggleExclude"
                                                  Tag="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Exclude from slideshow"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsExcluded,
                                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                             Value="True">
                                                                    <Setter Property="Text" Value="Include in slideshow"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Image.ContextMenu>
                            </Image>

                            <!-- Excluded indicator -->
                            <Border Background="#99000000" IsHitTestVisible="False" Margin="2" CornerRadius="2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExcluded}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" Foreground="#FF6B6B"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </DockPanel>

        <!-- ── Preview overlay (fade in/out) ──────────────────────────── -->
        <Grid x:Name="PreviewOverlayGrid" Background="#CC000000"
              MouseDown="PreviewOverlay_MouseDown"
              Focusable="True" KeyDown="PreviewOverlay_KeyDown"
              Opacity="0" IsHitTestVisible="False">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPreviewVisible}" Value="True">
                            <Setter Property="IsHitTestVisible" Value="True"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="12" Padding="20" Margin="16"
                    MaxWidth="440" MaxHeight="640"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MouseDown="PreviewContent_MouseDown"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewVisible}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                From="0.92" To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                From="0.92" To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Padding="6,4"
                                Command="{Binding ClosePreviewCommand}"
                                Background="Transparent" BorderThickness="0">
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="16"/>
                        </Button>
                        <TextBlock Text="{Binding PreviewFileName}"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    </DockPanel>

                    <Border Background="#111" Margin="0,0,0,10" MaxHeight="300" CornerRadius="6">
                        <Border.Clip>
                            <RectangleGeometry Rect="0,0,400,300" RadiusX="6" RadiusY="6"/>
                        </Border.Clip>
                        <Image MaxWidth="400" MaxHeight="300" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding SelectedImage.FilePath,
                                        Converter={x:Static local:ThumbnailConverter.Instance},
                                        ConverterParameter=400,
                                        IsAsync=True}"/>
                    </Border>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Padding="10,6"
                                Command="{Binding NavigatePreviousCommand}" ToolTip="Previous (Left key)">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Previous24" FontSize="14" Margin="0,0,4,0"/>
                                <TextBlock Text="Prev"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Grid.Column="1" Text="{Binding PreviewPositionText}"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   FontSize="10" FontFamily="Consolas"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Padding="10,6"
                                Command="{Binding NavigateNextCommand}" ToolTip="Next (Right key)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Next"/>
                                <ui:SymbolIcon Symbol="Next24" FontSize="14" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Dimensions:" Foreground="#888" FontSize="11" Margin="0,0,10,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewDimensions}" Foreground="#CCC" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="File size:" Foreground="#888" FontSize="11" Margin="0,0,10,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewFileSize}" Foreground="#CCC" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Path:" Foreground="#888" FontSize="11" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewPath}"
                                   Foreground="#AAA" FontSize="10" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
