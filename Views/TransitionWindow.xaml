<Window x:Class="BackgroundSlideShow.Views.TransitionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Black"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!--
        Full-screen overlay for crossfading between two wallpapers.
        AllowsTransparency=False: NewImage always covers the full window, so transparency
        is never needed. Avoiding WS_EX_LAYERED eliminates the DWM full-recomposition
        taskbar flash that layered windows cause on create/destroy.
        NewImage (bottom) stays opaque; OldImage (top) fades 1→0 to reveal it.
        Positioned directly below the desktop icon layer via DesktopInterop, so the
        transition shows through the DWM background while icons remain above us.
    -->
    <Grid>
        <Image x:Name="NewImage" Stretch="UniformToFill" IsHitTestVisible="False"/>
        <Image x:Name="OldImage" Stretch="UniformToFill" IsHitTestVisible="False"/>
    </Grid>

</Window>
