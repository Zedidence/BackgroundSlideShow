<Window x:Class="BackgroundSlideShow.Views.TransitionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!--
        A full-screen overlay that covers one monitor with the OLD wallpaper image,
        then fades to transparent — revealing the NEW wallpaper underneath.
        Opened by SlideshowEngine (via ShowTransitionOverlay delegate) before SetWallpaper is called.
    -->
    <Image x:Name="OldImage" Stretch="UniformToFill" IsHitTestVisible="False"/>

</Window>
