<Window x:Class="BackgroundSlideShow.Views.TransitionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!--
        Full-screen overlay that covers one monitor with the OLD wallpaper image.
        Sequence: Show overlay → block until first frame composited → SetWallpaper
        (new image set underneath) → BeginFade() → opacity 1→0 reveals the new wallpaper.
    -->
    <Image x:Name="OldImage" Stretch="UniformToFill" IsHitTestVisible="False"/>

</Window>
