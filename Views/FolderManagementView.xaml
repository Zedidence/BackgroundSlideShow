<UserControl x:Class="BackgroundSlideShow.Views.FolderManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:BackgroundSlideShow"
             xmlns:vm="clr-namespace:BackgroundSlideShow.ViewModels"
             AllowDrop="True"
             Drop="View_Drop"
             DragOver="View_DragOver">

    <DockPanel Margin="20,16,20,12">

        <!-- Page header + toolbar -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
            <TextBlock Text="Image Library" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Padding="10,6" Margin="0,0,8,0"
                        Command="{Binding AddFolderCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add24" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Add Folder"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Padding="10,6" Margin="0,0,8,0"
                        Command="{Binding ScanNowCommand}"
                        IsEnabled="{Binding IsScanning, Converter={x:Static local:BoolNegationConverter.Instance}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Scan All"/>
                    </StackPanel>
                </Button>

                <!-- Summary + scan status -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="{Binding SummaryText}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SummaryText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding ScanStatus}" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScanStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="3" Padding="8,6"
                        ToolTip="Remove all folders from the library"
                        Click="RemoveAll_Click"
                        Background="Transparent" BorderThickness="0" Foreground="#666">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DeleteDismiss24" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Remove All" FontSize="11"/>
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>

        <!-- Sort bar -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,14"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="6" Padding="10,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Sort by:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12" Margin="0,0,10,0"/>

                <!-- Name -->
                <Button Margin="0,0,4,0" Padding="8,4"
                        Command="{Binding SetSortCommand}"
                        CommandParameter="{x:Static vm:FolderSortMode.Name}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSortedByName}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Name" FontSize="11" VerticalAlignment="Center"/>
                        <ui:SymbolIcon FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Symbol" Value="ArrowUp24"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsSortedByName}" Value="True"/>
                                                <Condition Binding="{Binding SortAscending}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Symbol" Value="ArrowUp24"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsSortedByName}" Value="True"/>
                                                <Condition Binding="{Binding SortAscending}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Symbol" Value="ArrowDown24"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </StackPanel>
                </Button>

                <!-- Image Count -->
                <Button Margin="0,0,4,0" Padding="8,4"
                        Command="{Binding SetSortCommand}"
                        CommandParameter="{x:Static vm:FolderSortMode.ImageCount}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSortedByCount}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Images" FontSize="11" VerticalAlignment="Center"/>
                        <ui:SymbolIcon FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Symbol" Value="ArrowUp24"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsSortedByCount}" Value="True"/>
                                                <Condition Binding="{Binding SortAscending}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Symbol" Value="ArrowUp24"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsSortedByCount}" Value="True"/>
                                                <Condition Binding="{Binding SortAscending}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Symbol" Value="ArrowDown24"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </StackPanel>
                </Button>

                <!-- Last Scanned -->
                <Button Padding="8,4"
                        Command="{Binding SetSortCommand}"
                        CommandParameter="{x:Static vm:FolderSortMode.LastScanned}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSortedByLastScanned}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Last Scanned" FontSize="11" VerticalAlignment="Center"/>
                        <ui:SymbolIcon FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Symbol" Value="ArrowUp24"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsSortedByLastScanned}" Value="True"/>
                                                <Condition Binding="{Binding SortAscending}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Symbol" Value="ArrowUp24"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsSortedByLastScanned}" Value="True"/>
                                                <Condition Binding="{Binding SortAscending}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Symbol" Value="ArrowDown24"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Folder cards -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding SortedFolders}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FolderItemViewModel}">
                            <Border Margin="0,0,10,10" Padding="14,12" CornerRadius="8" Width="320"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <DockPanel LastChildFill="True">

                                    <!-- Remove button -->
                                    <Button DockPanel.Dock="Right" Padding="4,2" Margin="8,0,0,0"
                                            VerticalAlignment="Top" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding DataContext.RemoveFolderCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}">
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" Foreground="#666"/>
                                    </Button>

                                    <!-- Enable checkbox -->
                                    <CheckBox DockPanel.Dock="Left"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Top" Margin="0,2,10,0"
                                              ToolTip="Include this folder in the slideshow"/>

                                    <!-- Folder details -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter Property="Opacity" Value="0.45"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <!-- Folder name -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <ui:SymbolIcon Symbol="Folder24" FontSize="13" Margin="0,0,6,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Path}"/>
                                        </StackPanel>

                                        <!-- Full path -->
                                        <TextBlock Text="{Binding Path}" FontSize="10" Margin="0,0,0,6"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Path}"/>

                                        <!-- Stats row -->
                                        <StackPanel Orientation="Horizontal">
                                            <Border Padding="6,2" CornerRadius="4" Margin="0,0,6,0"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Image24" FontSize="10" Margin="0,0,4,0"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding ImageCount, StringFormat='{}{0:N0} images'}"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="6,2" CornerRadius="4"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Clock24" FontSize="10" Margin="0,0,4,0"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding LastScanned,
                                                                      Converter={x:Static local:RelativeTimeConverter.Instance}}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty-state hint -->
                <StackPanel Margin="0,60" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Folders.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="48" Foreground="#555"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="No folders added yet."
                               Foreground="#888" FontSize="14" TextAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Click Add Folder or drag folders here to get started."
                               Foreground="#666" FontSize="12" TextAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
