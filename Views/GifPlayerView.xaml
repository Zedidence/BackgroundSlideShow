<UserControl x:Class="BackgroundSlideShow.Views.GifPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Padding"          Value="16,9"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Padding"          Value="12,9"/>
            <Setter Property="Background"       Value="#3A3A3A"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,22" MaxWidth="580">

            <!-- ── Header ── -->
            <TextBlock Text="GIF Wallpaper Mode" Foreground="White"
                       FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" Foreground="#888" FontSize="12" Margin="0,0,0,24">
                Plays animated GIFs from a folder as live desktop wallpaper on every monitor.
                GIFs cycle at the interval you choose below. The existing static slideshow
                continues running underneath and reappears when you stop GIF mode.
            </TextBlock>

            <!-- ── Folder picker ── -->
            <TextBlock Text="GIF FOLDER" Foreground="#666" FontSize="10"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <DockPanel Margin="0,0,0,22">
                <Button DockPanel.Dock="Right" Content="Browse…"
                        Command="{Binding BrowseFolderCommand}"
                        Style="{StaticResource SmallBtn}"
                        Margin="6,0,0,0"/>
                <Border Background="#2D2D2D" BorderBrush="#444" BorderThickness="1"
                        Padding="10,7" CornerRadius="3">
                    <TextBlock Text="{Binding GifFolderPath, FallbackValue='No folder selected'}"
                               Foreground="#CCCCCC" FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding GifFolderPath}"/>
                </Border>
            </DockPanel>

            <!-- ── Duration ── -->
            <TextBlock Text="SECONDS PER GIF" Foreground="#666" FontSize="10"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <DockPanel Margin="0,0,0,26">
                <TextBlock DockPanel.Dock="Right" Width="44" TextAlignment="Right"
                           Foreground="White" FontFamily="Consolas" FontSize="13"
                           VerticalAlignment="Center"
                           Text="{Binding SecondsPerFile, StringFormat='{}{0} s'}"/>
                <Slider Value="{Binding SecondsPerFile, Mode=TwoWay}"
                        Minimum="3" Maximum="120"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="0,0,8,0"/>
            </DockPanel>

            <!-- ── Controls ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                <!-- Start -->
                <Button Content="▶  Start" Command="{Binding StartCommand}"
                        IsEnabled="{Binding HasFolder}"
                        Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                            <Setter Property="Background" Value="#2E6DA4"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#2D2D2D"/>
                                    <Setter Property="Foreground" Value="#555"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A80BE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Stop -->
                <Button Content="■  Stop" Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Margin="0,0,14,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                            <Setter Property="Background" Value="#883333"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#2D2D2D"/>
                                    <Setter Property="Foreground" Value="#555"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#AA3333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Prev / Next (only meaningful while running) -->
                <Button Content="◀" Command="{Binding PrevCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Style="{StaticResource SmallBtn}"
                        Margin="0,0,4,0" ToolTip="Previous GIF"/>
                <Button Content="▶" Command="{Binding NextCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Style="{StaticResource SmallBtn}"
                        ToolTip="Next GIF"/>
            </StackPanel>

            <!-- ── Status ── -->
            <Border Background="#252525" BorderBrush="#3A3A3A" BorderThickness="1"
                    Padding="14,11" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="NOW PLAYING" Foreground="#555" FontSize="9"
                               FontWeight="SemiBold" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#AAAAAA" FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
