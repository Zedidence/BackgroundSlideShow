<UserControl x:Class="BackgroundSlideShow.Views.GifPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="580">

            <TextBlock Text="GIF Wallpaper Mode"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,28">
                Plays animated GIFs from a folder as live desktop wallpaper on every monitor.
                GIFs cycle at the interval you choose below.
            </TextBlock>

            <!-- Folder picker -->
            <TextBlock Text="GIF FOLDER"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DockPanel Margin="0,0,0,26">
                <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="12,7"
                        Command="{Binding BrowseFolderCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Browse"/>
                    </StackPanel>
                </Button>
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" Padding="12,8" CornerRadius="6">
                    <TextBlock Text="{Binding GifFolderPath, FallbackValue='No folder selected'}"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               FontSize="12" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding GifFolderPath}"/>
                </Border>
            </DockPanel>

            <!-- Duration -->
            <TextBlock Text="SECONDS PER GIF"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DockPanel Margin="0,0,0,30">
                <TextBlock DockPanel.Dock="Right" Width="44" TextAlignment="Right"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"
                           Text="{Binding SecondsPerFile, StringFormat='{}{0} s'}"/>
                <Slider Value="{Binding SecondsPerFile, Mode=TwoWay}"
                        Minimum="3" Maximum="120"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="0,0,10,0"/>
            </DockPanel>

            <!-- Controls -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                <Button Command="{Binding StartCommand}"
                        IsEnabled="{Binding HasFolder}"
                        Margin="0,0,8,0" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Play24" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Start"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Margin="0,0,16,0" Padding="14,8"
                        Background="#3A1A1A" Foreground="#CC6666" BorderBrush="#5C2A2A">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Stop24" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Stop"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding PrevCommand}" IsEnabled="{Binding IsRunning}"
                        Padding="8,8" Margin="0,0,4,0" ToolTip="Previous GIF">
                    <ui:SymbolIcon Symbol="Previous24" FontSize="14"/>
                </Button>
                <Button Command="{Binding NextCommand}" IsEnabled="{Binding IsRunning}"
                        Padding="8,8" ToolTip="Next GIF">
                    <ui:SymbolIcon Symbol="Next24" FontSize="14"/>
                </Button>
            </StackPanel>

            <!-- Status -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" Padding="16,12" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="NOW PLAYING"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               FontSize="9" FontWeight="SemiBold" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
