<UserControl x:Class="BackgroundSlideShow.Views.LockScreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:BackgroundSlideShow.Models"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="16,9"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Padding"    Value="12,9"/>
            <Setter Property="Background" Value="#3A3A3A"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,22" MaxWidth="580">

            <!-- ── Header ── -->
            <TextBlock Text="Lock Screen Slideshow" Foreground="White"
                       FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" Foreground="#888" FontSize="12" Margin="0,0,0,24">
                Rotates your Windows lock screen through images from a folder.
                The image cycles automatically while the app is running. When
                you lock your PC, you'll see the most recently applied image.
            </TextBlock>

            <!-- ── Folder picker ── -->
            <TextBlock Text="IMAGE FOLDER" Foreground="#666" FontSize="10"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <DockPanel Margin="0,0,0,22">
                <Button DockPanel.Dock="Right" Content="Browse…"
                        Command="{Binding BrowseFolderCommand}"
                        Style="{StaticResource SmallBtn}"
                        Margin="6,0,0,0"/>
                <Border Background="#2D2D2D" BorderBrush="#444" BorderThickness="1"
                        Padding="10,7" CornerRadius="3">
                    <TextBlock FontSize="12" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding FolderPath}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="{Binding FolderPath}"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasFolder}" Value="False">
                                        <Setter Property="Text"       Value="No folder selected"/>
                                        <Setter Property="Foreground" Value="#666"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </DockPanel>

            <!-- ── Interval ── -->
            <TextBlock Text="MINUTES PER IMAGE" Foreground="#666" FontSize="10"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <DockPanel Margin="0,0,0,26">
                <TextBlock DockPanel.Dock="Right" Width="52" TextAlignment="Right"
                           Foreground="White" FontFamily="Consolas" FontSize="13"
                           VerticalAlignment="Center"
                           Text="{Binding IntervalMinutes, StringFormat='{}{0} min'}"/>
                <Slider Value="{Binding IntervalMinutes, Mode=TwoWay}"
                        Minimum="1" Maximum="120"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="0,0,8,0"/>
            </DockPanel>

            <!-- ── Image framing ── -->
            <TextBlock Text="IMAGE FRAMING" Foreground="#666" FontSize="10"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <ComboBox SelectedValue="{Binding FitMode, Mode=TwoWay}"
                      SelectedValuePath="Tag"
                      Background="#2D2D2D" Foreground="White"
                      BorderBrush="#444" FontSize="12"
                      Margin="0,0,0,22" Width="220" HorizontalAlignment="Left">
                <ComboBoxItem Content="Fill (cover-crop)"  Tag="{x:Static models:FitMode.Fill}"
                              ToolTip="Scale to fill; edges are cropped"/>
                <ComboBoxItem Content="Fit (letterbox)"    Tag="{x:Static models:FitMode.Fit}"
                              ToolTip="Scale to fit within screen; black bars fill the rest"/>
                <ComboBoxItem Content="Stretch"            Tag="{x:Static models:FitMode.Stretch}"
                              ToolTip="Stretch to fill exactly, ignoring aspect ratio"/>
                <ComboBoxItem Content="Center"             Tag="{x:Static models:FitMode.Center}"
                              ToolTip="Show at native size centered; scale down only if too large"/>
                <ComboBoxItem Content="Tile"               Tag="{x:Static models:FitMode.Tile}"
                              ToolTip="Tile image repeatedly across the screen"/>
            </ComboBox>

            <!-- ── Collage toggle ── -->
            <CheckBox Content="Enable photo collages (shown every 4–8 images, requires 3+ images)"
                      IsChecked="{Binding CollageEnabled, Mode=TwoWay}"
                      Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,22"
                      Cursor="Hand"/>

            <!-- ── Controls ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                <!-- Start -->
                <Button Content="▶  Start" Command="{Binding StartCommand}"
                        IsEnabled="{Binding HasFolder}"
                        Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                            <Setter Property="Background" Value="#2E6DA4"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#2D2D2D"/>
                                    <Setter Property="Foreground" Value="#555"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A80BE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Stop -->
                <Button Content="■  Stop" Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Margin="0,0,14,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                            <Setter Property="Background" Value="#883333"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#2D2D2D"/>
                                    <Setter Property="Foreground" Value="#555"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#AA3333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Next -->
                <Button Content="▶" Command="{Binding NextCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Style="{StaticResource SmallBtn}"
                        ToolTip="Apply next image now"/>
            </StackPanel>

            <!-- ── Status ── -->
            <Border Background="#252525" BorderBrush="#3A3A3A" BorderThickness="1"
                    Padding="14,11" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="NOW SHOWING" Foreground="#555" FontSize="9"
                               FontWeight="SemiBold" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
