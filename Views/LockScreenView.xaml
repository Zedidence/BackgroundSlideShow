<UserControl x:Class="BackgroundSlideShow.Views.LockScreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:BackgroundSlideShow.Models">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="580">

            <TextBlock Text="Lock Screen Slideshow"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,28">
                Rotates your Windows lock screen through images from a folder.
                The image cycles automatically while the app is running.
            </TextBlock>

            <!-- Folder picker -->
            <TextBlock Text="IMAGE FOLDER"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DockPanel Margin="0,0,0,26">
                <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="12,7"
                        Command="{Binding BrowseFolderCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Browse"/>
                    </StackPanel>
                </Button>
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" Padding="12,8" CornerRadius="6">
                    <TextBlock FontSize="12" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding FolderPath}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding FolderPath}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasFolder}" Value="False">
                                        <Setter Property="Text" Value="No folder selected"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </DockPanel>

            <!-- Interval -->
            <TextBlock Text="MINUTES PER IMAGE"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DockPanel Margin="0,0,0,26">
                <TextBlock DockPanel.Dock="Right" Width="52" TextAlignment="Right"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"
                           Text="{Binding IntervalMinutes, StringFormat='{}{0} min'}"/>
                <Slider Value="{Binding IntervalMinutes, Mode=TwoWay}"
                        Minimum="1" Maximum="120"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="0,0,10,0"/>
            </DockPanel>

            <!-- Image framing -->
            <TextBlock Text="IMAGE FRAMING"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ComboBox SelectedValue="{Binding FitMode, Mode=TwoWay}"
                      SelectedValuePath="Tag" FontSize="12"
                      Margin="0,0,0,22" Width="220" HorizontalAlignment="Left">
                <ComboBoxItem Content="Fill (cover-crop)"  Tag="{x:Static models:FitMode.Fill}"/>
                <ComboBoxItem Content="Fit (letterbox)"    Tag="{x:Static models:FitMode.Fit}"/>
                <ComboBoxItem Content="Stretch"            Tag="{x:Static models:FitMode.Stretch}"/>
                <ComboBoxItem Content="Center"             Tag="{x:Static models:FitMode.Center}"/>
                <ComboBoxItem Content="Tile"               Tag="{x:Static models:FitMode.Tile}"/>
            </ComboBox>

            <!-- Collage -->
            <ui:ToggleSwitch Content="Enable photo collages (shown every 4&#x2013;8 images)"
                             IsChecked="{Binding CollageEnabled, Mode=TwoWay}"
                             Margin="0,0,0,26"/>

            <!-- Controls -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                <Button Command="{Binding StartCommand}"
                        IsEnabled="{Binding HasFolder}"
                        Margin="0,0,8,0" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Play24" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Start"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Margin="0,0,16,0" Padding="14,8"
                        Background="#3A1A1A" Foreground="#CC6666" BorderBrush="#5C2A2A">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Stop24" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Stop"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NextCommand}" IsEnabled="{Binding IsRunning}"
                        Padding="8,8" ToolTip="Apply next image now">
                    <ui:SymbolIcon Symbol="Next24" FontSize="14"/>
                </Button>
            </StackPanel>

            <!-- Status -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" Padding="16,12" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="NOW SHOWING"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               FontSize="9" FontWeight="SemiBold" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
